# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/smart-college

# Auth0 Configuration
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_AUDIENCE=https://smart-college-api
AUTH0_CLIENT_ID=your_client_id
AUTH0_CLIENT_SECRET=your_client_secret
AUTH0_MANAGEMENT_CLIENT_ID=your_management_client_id
AUTH0_MANAGEMENT_CLIENT_SECRET=your_management_client_secret

# OpenAI
OPENAI_API_KEY=sk-your-openai-key

# SerpAPI (for AI Mentor web search)
SERP_API_KEY=your_serp_api_key

# Email Configuration (for user provisioning)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Institution Settings
INSTITUTION_NAME=Your College Name
INSTITUTION_DOMAIN=yourcollege.edu
INSTITUTION_CODE=YC

# JWT Secret for internal tokens
JWT_SECRET=your-super-secret-jwt-key-change-this
